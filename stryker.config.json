{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "reporters": ["html", "clear-text", "progress"],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "coverageAnalysis": "perTest",
  "mutate": ["src/utils/**/*.ts", "src/composables/**/*.ts"],
  "ignorePatterns": [
    "dist",
    "docs/.vitepress/dist",
    "docs/.vitepress/cache",
    "coverage",
    "reports",
    "tests-e2e",
    "playwright-report",
    "test-results"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 60
  },
  "timeoutMS": 15000
}
